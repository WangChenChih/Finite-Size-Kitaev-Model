doi = {10.1088/1751-8113/47/15/155301},
url = {https://doi.org/10.1088/1751-8113/47/15/155301},
year = {2014},
month = {mar},
publisher = {IOP Publishing},
volume = {47},
number = {15},
pages = {155301},
author = {Hofmann, Martin and Moroder, Tobias and Gühne, Otfried},
title = {Analytical characterization of the genuine multiparticle negativity},
journal = {Journal of Physics A: Mathematical and Theoretical},
abstract = {The genuine multiparticle negativity is a measure of genuine multiparticle entanglement which can be numerically calculated. We present several results of how this entanglement measure can be characterized in an analytical way. First, we show that with an appropriate normalization this measure can be seen as coming from a mixed convex roof construction. Based on this, we determine its value for n-qubit GHZ-diagonal states and four-qubit cluster-diagonal states.}
}

